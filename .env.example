PUSHER_CLUSTER=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
# NavPro (Trucker Path partner API)
# Flip RELAY_ADAPTER to `navpro` once relay-credentials.json is in place.
# `mock` serves data/*.json — works offline, no creds required.
# See API_DOCS/NavPro_integration.md for the full integration guide.
RELAY_ADAPTER=mock
NAVPRO_BASE_URL=https://api.truckerpath.com/navpro
NAVPRO_CREDENTIALS_PATH=./relay-credentials.json
NAVPRO_WEBHOOK_SECRET=
