# Copy to .env.local and fill in values. NEXT_PUBLIC_* are exposed to the browser.

# FastAPI backend base URL (Heroku/Fly URL in prod, http://localhost:8000 in dev)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Bearer token for /dispatcher/* and /internal/* routes.
# Matches RELAY_INTERNAL_TOKEN on the backend. Leave empty in dev if the backend
# is running without a token configured (it will bypass auth with a warning).
NEXT_PUBLIC_RELAY_TOKEN=

# Pusher WebSocket (channel: dispatcher.${NEXT_PUBLIC_DISPATCHER_ID})
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=us3
NEXT_PUBLIC_DISPATCHER_ID=demo
